# ScholarPath Africa - Environment Variables
# Copy this file to .env.local and fill in your values

# Database (SQLite path - relative to project root)
DATABASE_PATH=./scholarpath.db

# JWT Secret for admin authentication (generate a random 64-char string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-64-chars

# Admin credentials (change before deploying!)
ADMIN_EMAIL=admin@scholarpath.africa
ADMIN_PASSWORD=ChangeMe123!

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google AdSense (optional - for monetization)
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
